from typing import TypedDict
from langchain.chat_models import init_chat_model

# 1. Define the Schema (Structure)                
class User(TypedDict):                                ###################### Typedict
    """Information about a specific user."""          ###################### simple explain what in data
    name: str
    age: int
    email: str

# 2. Initialize the Model
model = init_chat_model("gpt-4o", model_provider="openai", temperature=0)

# 3. Bind the Schema for Structured Output
structured_llm = model.with_structured_output(User)     ############ .with_structured_output(CLASSNAME)

# 4. Invoke and Print
query = "Hi, I am Dheeraj, age is 32 and my email id is dheeraj@gmail.com"
output = structured_llm.invoke(query)

print(output)
# Result: {'name': 'Dheeraj', 'age': 32, 'email': 'dheeraj@gmail.com'}
